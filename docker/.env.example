# ============================================
# EV 充电平台 - 环境变量配置
# ============================================
# 复制此文件为 .env 并根据实际情况修改配置

# ============================================
# PostgreSQL 配置
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=ev_platform
POSTGRES_PORT=5432

# 数据库名称配置
IDENTITY_DB_NAME=ev_identity
STATION_DB_NAME=ev_station
CHARGING_DB_NAME=ev_charging
ORDER_DB_NAME=ev_order

# ============================================
# Redis 配置
# ============================================
REDIS_PASSWORD=your_redis_password_here
REDIS_PORT=6379
REDIS_MAXMEMORY=512mb

# ============================================
# Kafka 配置
# ============================================
KAFKA_PORT=9092
KAFKA_LOG_RETENTION_HOURS=168
KAFKA_LOG_SEGMENT_BYTES=1073741824

# ============================================
# Nacos 配置
# ============================================
NACOS_PORT=8848
NACOS_XMS=256m
NACOS_XMX=512m
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=your_nacos_auth_token_here
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=your_nacos_identity_value_here
NACOS_SERVER_ADDR=nacos:8848
NACOS_NAMESPACE=

# ============================================
# MinIO 配置
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ============================================
# 后端服务端口配置
# ============================================
GATEWAY_PORT=8080
IDENTITY_PORT=8081
STATION_PORT=8082
CHARGING_PORT=8084
ORDER_PORT=8083

# ============================================
# JWT 配置
# ============================================
JWT_SECRET=your_jwt_secret_key_here_min_32_characters

# ============================================
# Nginx 配置
# ============================================
HTTP_PORT=80
HTTPS_PORT=443

# ============================================
# 应用配置
# ============================================
SPRING_PROFILES_ACTIVE=prod
