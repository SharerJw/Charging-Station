# ============================================
# EV 充电平台 - 环境变量配置
# ============================================
# 复制此文件为 .env 并根据实际情况修改配置
# docker compose 会自动加载同目录下的 .env 文件
# 注意：修改后需同步更新 docker-compose.yml 中对应的硬编码值

# ============================================
# PostgreSQL 配置
# ============================================
# 数据库超级用户名（docker-compose.yml 中所有服务共用此用户）
POSTGRES_USER=ev
# 数据库超级用户密码（docker-compose.yml 中所有服务共用此密码）
POSTGRES_PASSWORD=ev123
# 默认数据库名（init.sql 会在此基础上创建其他业务库）
POSTGRES_DB=ev_identity
# PostgreSQL 对外端口
POSTGRES_PORT=5432

# ============================================
# Redis 配置
# ============================================
# Redis 对外端口（docker-compose.yml 中 Redis 未设置密码认证）
REDIS_PORT=6379

# ============================================
# Kafka 配置
# ============================================
# Kafka 对外端口
KAFKA_PORT=9092
# 日志保留时长（小时），超过后自动清理
KAFKA_LOG_RETENTION_HOURS=168

# ============================================
# Nacos 配置
# ============================================
# Nacos 对外端口（主端口）
NACOS_PORT=8848
# Nacos JVM 初始堆内存
NACOS_XMS=256m
# Nacos JVM 最大堆内存
NACOS_XMX=256m

# ============================================
# MinIO 配置
# ============================================
# MinIO 管理员用户名
MINIO_ROOT_USER=minioadmin
# MinIO 管理员密码
MINIO_ROOT_PASSWORD=minioadmin
# MinIO API 对外端口
MINIO_PORT=9000
# MinIO 管理控制台对外端口
MINIO_CONSOLE_PORT=9001

# ============================================
# 后端微服务端口配置
# ============================================
# API 网关端口（统一入口）
GATEWAY_PORT=8080
# 认证服务端口
IDENTITY_PORT=8081
# 站点服务端口
STATION_PORT=8082
# 订单服务端口
ORDER_PORT=8083
# 充电服务端口
CHARGING_PORT=8084
# 模拟器服务端口
SIMULATOR_PORT=8085

# ============================================
# Spring 配置
# ============================================
# Spring 激活的配置文件（prod = 生产环境，dev = 开发环境）
SPRING_PROFILES_ACTIVE=prod
